generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum Grade {
  S
  A_PLUS @map("A+")
  A
  B
  C
}

enum PhoneUnitStatus {
  AVAILABLE
  RESERVED
  SOLD
  IN_REPAIR
  DEFECTIVE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum StockMovementType {
  UNIT_ADDED
  UNIT_SOLD
  UNIT_STATUS_CHANGED
  UNIT_DELETED
  GENERIC_SALE
  GENERIC_RESTOCK
  GENERIC_ADJUSTMENT
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  role          Role
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  
  createdById   String?   @map("created_by") @db.Uuid
  createdBy     User?     @relation("UserCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdUsers  User[]    @relation("UserCreator")
  
  productsCreated Product[] @relation("CreatedProducts")
  productsUpdated Product[] @relation("UpdatedProducts")
  
  unitsCreated  PhoneUnit[] @relation("CreatedPhoneUnits")
  unitsUpdated  PhoneUnit[] @relation("UpdatedPhoneUnits")
  
  bills         Bill[]
  stockMovements StockMovement[]
  auditLogs     AuditLog[]
  systemConfigs SystemConfig[]

  @@map("users")
}

model Category {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?    @map("image_url")
  parentId    String?    @map("parent_id") @db.Uuid
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz

  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Restrict)
  children    Category[] @relation("CategoryToCategory")
  products    Product[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Brand {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  products  Product[]

  @@index([slug])
  @@index([isActive])
  @@map("brands")
}

model Product {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku                 String     @unique
  name                String
  slug                String     @unique
  description         String?
  brandId             String     @map("brand_id") @db.Uuid
  categoryId          String     @map("category_id") @db.Uuid
  baseCondition       Condition  @map("base_condition")
  basePrice           Decimal    @map("base_price") @db.Decimal(10, 2)
  compareAtPrice      Decimal?   @map("compare_at_price") @db.Decimal(10, 2)
  specifications      Json       @default("{}")
  isUnitTracked       Boolean    @default(true) @map("is_unit_tracked")
  availableUnitCount  Int        @default(0) @map("available_unit_count")
  stockQuantity       Int        @default(0) @map("stock_quantity")
  isListed            Boolean    @default(false) @map("is_listed")
  visibilityOverride  Boolean    @default(false) @map("visibility_override")
  isFeatured          Boolean    @default(false) @map("is_featured")
  internalNotes       String?    @map("internal_notes")
  version             Int        @default(1)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz
  
  createdBy           String     @map("created_by") @db.Uuid
  updatedBy           String     @map("updated_by") @db.Uuid

  brand               Brand      @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category            Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  creator             User       @relation("CreatedProducts", fields: [createdBy], references: [id], onDelete: Restrict)
  updater             User       @relation("UpdatedProducts", fields: [updatedBy], references: [id], onDelete: Restrict)

  images              ProductImage[]
  phoneUnits          PhoneUnit[]
  billItems           BillItem[]
  stockMovements      StockMovement[]

  @@index([slug])
  @@index([sku])
  @@index([brandId])
  @@index([categoryId])
  @@index([isListed])
  @@index([deletedAt])
  @@index([availableUnitCount])
  @@index([stockQuantity])
  @@index([isListed, deletedAt, availableUnitCount])
  @@map("products")
}

model PhoneUnit {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId              String    @map("product_id") @db.Uuid
  sku                    String    @unique
  imei                   String?
  storage                String?
  color                  String?
  batteryHealth          Int?      @map("battery_health")
  grade                  Grade?
  condition              Condition
  hasBox                 Boolean   @default(false) @map("has_box")
  hasCharger             Boolean   @default(false) @map("has_charger")
  hasEarphones           Boolean   @default(false) @map("has_earphones")
  hasOriginalAccessories Boolean   @default(false) @map("has_original_accessories")
  warrantyInfo           String?   @map("warranty_info")
  sellingPrice           Decimal?  @map("selling_price") @db.Decimal(10, 2)
  purchasePrice          Decimal?  @map("purchase_price") @db.Decimal(10, 2)
  status                 PhoneUnitStatus @default(AVAILABLE)
  adminNotes             String?   @map("admin_notes")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz
  
  createdBy              String    @map("created_by") @db.Uuid
  updatedBy              String    @map("updated_by") @db.Uuid

  product                Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  creator                User      @relation("CreatedPhoneUnits", fields: [createdBy], references: [id], onDelete: Restrict)
  updater                User      @relation("UpdatedPhoneUnits", fields: [updatedBy], references: [id], onDelete: Restrict)

  billItems              BillItem[]
  stockMovements         StockMovement[]

  @@index([productId])
  @@index([sku])
  @@index([status])
  @@index([deletedAt])
  @@index([productId, status, deletedAt])
  @@index([imei])
  @@map("phone_units")
}

model ProductImage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  cloudinaryId String   @map("cloudinary_id")
  url          String
  altText      String   @default("") @map("alt_text")
  sortOrder    Int      @default(0) @map("sort_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([productId, isPrimary])
  @@map("product_images")
}

model Bill {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billNumber    String        @unique @map("bill_number")
  staffId       String        @map("staff_id") @db.Uuid
  customerName  String?       @map("customer_name")
  customerPhone String?       @map("customer_phone")
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  staff         User          @relation(fields: [staffId], references: [id], onDelete: Restrict)
  billItems     BillItem[]

  @@index([staffId])
  @@index([createdAt])
  @@index([billNumber])
  @@map("bills")
}

model BillItem {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billId                String    @map("bill_id") @db.Uuid
  productId             String    @map("product_id") @db.Uuid
  phoneUnitId           String?   @map("phone_unit_id") @db.Uuid
  quantity              Int
  unitPrice             Decimal   @map("unit_price") @db.Decimal(10, 2)
  discount              Decimal   @default(0) @db.Decimal(10, 2)
  lineTotal             Decimal   @map("line_total") @db.Decimal(10, 2)
  
  // Denormalized fields
  productName           String    @map("product_name")
  productSku            String    @map("product_sku")
  unitSku               String?   @map("unit_sku")
  unitGrade             String?   @map("unit_grade")
  unitStorage           String?   @map("unit_storage")
  unitColor             String?   @map("unit_color")
  unitCondition         String?   @map("unit_condition")
  unitHasBox            Boolean?  @map("unit_has_box")
  unitHasCharger        Boolean?  @map("unit_has_charger")
  unitImei              String?   @map("unit_imei")

  bill                  Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  product               Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  phoneUnit             PhoneUnit? @relation(fields: [phoneUnitId], references: [id], onDelete: Restrict)

  @@index([billId])
  @@index([productId])
  @@index([phoneUnitId])
  @@map("bill_items")
}

model StockMovement {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId        String            @map("product_id") @db.Uuid
  phoneUnitId      String?           @map("phone_unit_id") @db.Uuid
  movementType     StockMovementType @map("movement_type")
  quantityChange   Int               @map("quantity_change")
  quantityBefore   Int               @map("quantity_before")
  quantityAfter    Int               @map("quantity_after")
  unitStatusBefore String?           @map("unit_status_before")
  unitStatusAfter  String?           @map("unit_status_after")
  referenceType    String?           @map("reference_type")
  referenceId      String?           @map("reference_id") @db.Uuid
  notes            String?
  createdBy        String            @map("created_by") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz

  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  phoneUnit        PhoneUnit?        @relation(fields: [phoneUnitId], references: [id], onDelete: Restrict)
  creator          User              @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([phoneUnitId])
  @@index([createdAt])
  @@index([movementType])
  @@index([productId, createdAt])
  @@map("stock_movements")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy   String?  @map("updated_by") @db.Uuid

  updater     User?    @relation(fields: [updatedBy], references: [id], onDelete: Restrict)

  @@map("system_config")
}
